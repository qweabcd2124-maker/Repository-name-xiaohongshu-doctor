# === LLM 配置 ===
# 选择 LLM 提供商: openai (默认) 或 anthropic
LLM_PROVIDER=openai

# OpenAI 配置（LLM_PROVIDER=openai 时需要）
# API Key 填在 OPENAI_API_KEY，不要填在 OPENAI_BASE_URL
OPENAI_API_KEY=
# 留空 = 官方 https://api.openai.com/v1
# 小米 MiMo OpenAI 兼容网关（二选一，以控制台为准）：
# OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
# OPENAI_BASE_URL=https://api.mimo-v2.com/v1
OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
# 显式声明兼容小米网关（可选；或设 LLM_MODEL=mimo-v2-omni / BASE_URL 含 xiaomimimo、mimo-v2）
# OPENAI_COMPAT=mimoj
# 模型名（与所用接口一致）。OpenAI：gpt-4o；小米：mimo-v2-omni
LLM_MODEL=mimo-v2-omni
# 多模态/快识（未设时部分模块回退到 LLM_MODEL 同名变量见代码）
# LLM_MODEL_OMNI=mimo-v2-omni
# 快识专用：必须是多模态模型，flash不支持识图！（留空则用 LLM_MODEL_OMNI）
# LLM_MODEL_QUICK_RECOGNIZE=mimo-v2-omni
# 快识：输出 token 上限（JSON 较短，默认 640 利于 <5s）
# QUICK_RECOGNIZE_MAX_COMPLETION_TOKENS=640
# 快识：正文补全 OCR 第二次调用的 token 上限（默认 512）
# QUICK_RECOGNIZE_OCR_MAX_TOKENS=512
# 快识：长边像素上限（超过才压 JPEG；默认 1280；偏小更快、極小字可能略损）
# QUICK_RECOGNIZE_MAX_EDGE=1280
# QUICK_RECOGNIZE_JPEG_QUALITY=90
# 网关不支持 response_format=json_object 时可设 1
# LLM_SKIP_JSON_RESPONSE_FORMAT=1

# Anthropic 配置（LLM_PROVIDER=anthropic 时需要）
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# === 服务器配置 ===
BACKEND_PORT=8000
FRONTEND_PORT=5173

# === Temporary video URL (for MiMo video_url mode without object storage) ===
# Public base URL that MiMo can access. Example: https://your-domain.com
# If empty, backend will use incoming request base_url (may be unreachable from public internet).
MIMO_VIDEO_PUBLIC_BASE_URL=

# HMAC key for signed temporary video links. Please set a strong random string in production.
TEMP_VIDEO_SIGNING_KEY=change-me-to-a-long-random-secret

# Temporary video link TTL in seconds (default 900 = 15 minutes)
TEMP_VIDEO_TTL_SECONDS=900

# Optional custom temp video directory
# TEMP_VIDEO_DIR=backend/data/temp_videos
