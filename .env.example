# === LLM 配置 ===
# 选择 LLM 提供商: openai (默认) 或 anthropic
LLM_PROVIDER=openai

# OpenAI 配置（LLM_PROVIDER=openai 时需要）
OPENAI_API_KEY=
# 留空 = 官方 api.openai.com；第三方兼容接口示例：DeepSeek 填 https://api.deepseek.com
OPENAI_BASE_URL=sk-aa15165d5e914f49b054a97049e15320
# 模型名（与所用接口一致）。OpenAI 示例：gpt-4o；DeepSeek 示例：deepseek-chat
LLM_MODEL=deepseek-chat

# Anthropic 配置（LLM_PROVIDER=anthropic 时需要）
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# === 服务器配置 ===
BACKEND_PORT=8000
FRONTEND_PORT=5173
